# https://aistudio.google.com/apikey
GOOGLE_AI_API_KEY=

# Open-weight Gemma 4 (hosted on the same Google AI / Gemini API — not a separate integration).
# Default in code is gemma-4-31b-it; override here if needed. Examples:
#   gemma-4-31b-it       (dense 31B — default)
#   gemma-4-26b-a4b-it   (26B MoE — often faster / different quota)
GOOGLE_AI_MODEL=gemma-4-31b-it

# Optional: max attempts per model call (default 5). Retries rate limits (429) and 5xx / transient network errors.
# GOOGLE_AI_MAX_RETRIES=5

# Parallel hypothesis-leaf analyses — cap Gemini calls in flight (default 3 on Vercel, 4 locally; max 16). Set to 1 for fully serial behavior.
# ANALYSIS_CONCURRENCY=4

# After each leaf analysis: manager pressure-test + one refinement pass (default on). Set off to save latency/cost.
# LEAF_MANAGER_REVIEW=true

# Back-compat only — use GOOGLE_AI_MODEL instead
# GEMINI_MODEL=

# Neon, Supabase, or Vercel Postgres — pooled connection string for serverless
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"
# Unpooled connection used by Prisma CLI only (migrate / db push); the app
# runtime uses DATABASE_URL. On Neon, point this at the direct (non-pooler)
# endpoint. If you don't use a pooler, set it to the same value as DATABASE_URL.
DIRECT_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# --- Quant data backend ---------------------------------------------------
# Dataset catalog (JSON: { datasets: DatasetMeta[] }). Default is the synthetic
# prototype catalog. A private deployment points this at its own catalog of real
# warehouse tables (source.kind=clickhouse, etc.).
# CATALOG_FILE=config/catalog.dummy.json
#
# Quant provider — the SQL backend the agent queries. Default "duckdb-csv" loads
# the prototype CSVs into in-memory DuckDB. The registry resolves the value to a
# module under src/lib/quant/providers/, so a private deployment adds e.g.
# providers/clickhouse.ts and sets QUANT_PROVIDER=clickhouse.
# QUANT_PROVIDER=duckdb-csv

# If status is "running" but no stream is alive (e.g. Vercel timeout), reconnect after this many ms
# without last DB touch treats the run as stale and resumes. On Vercel the default is ~25s unless set.
# STALE_RUNNING_MS=25000
