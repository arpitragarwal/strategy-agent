# https://aistudio.google.com/apikey
GOOGLE_AI_API_KEY=

# Open-weight Gemma 4 (hosted on the same Google AI / Gemini API — not a separate integration).
# Pick the smallest model your project lists in AI Studio. Examples:
#   gemma-4-26b-a4b-it  (26B MoE — default below, often cheaper than 31B dense)
#   gemma-4-31b-it       (dense; documented at ai.google.dev/gemma/docs/core/gemma_on_gemini_api)
GOOGLE_AI_MODEL=gemma-4-26b-a4b-it

# Optional: max attempts per model call (default 5). Retries rate limits (429) and 5xx / transient network errors.
# GOOGLE_AI_MAX_RETRIES=5

# Back-compat only — use GOOGLE_AI_MODEL instead
# GEMINI_MODEL=

# Neon, Supabase, or Vercel Postgres — pooled connection string for serverless
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"
