generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model StrategyRun {
  id              String   @id @default(cuid())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  status          String   @default("pending")
  /// step_by_step = pause for human review between major phases; end_to_end = run without those pauses
  runMode         String   @default("step_by_step")
  /// When status is awaiting_review: after_discovery | after_structure | after_analysis
  reviewCheckpoint String?
  prompt          String   @db.Text
  companyContext  String   @default("") @db.Text
  discoveryOutput String?  @db.Text
  /// Optional answers to clarifying questions from the context step; merged into discoveryOutput before structure when user continues.
  clarificationAnswers String? @db.Text
  outline         Json?
  /// Manager critique of the hypothesis tree before leaf analysis; structure is then revised
  treeReviewNotes String?  @db.Text
  nodeStates      Json?
  managerNotes    String?  @db.Text
  synthesis       String?  @db.Text
  progressLog     Json     @default("[]")
  error           String?  @db.Text
  /// User interrupt: synthesize_now | redirect (consumed by orchestrator when checked)
  controlAction   String?
  controlNote     String?  @db.Text
  /// Appended steering notes from redirects; injected into remaining leaf analyses
  redirectContext String  @default("") @db.Text
  synthesisIsPartial Boolean @default(false)
}

model MemoryArtifact {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  /// When the strategy run began (copied from StrategyRun.createdAt) for display in Memory
  runStartedAt DateTime?
  title     String
  summary   String   @db.Text
  topics    String   @default("") @db.Text
  payload   Json
  runId     String?
}
