generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // Pooled (PgBouncer) endpoint for the app at runtime.
  url       = env("DATABASE_URL")
  // Unpooled endpoint for Prisma CLI (migrate / db push), which can't run
  // through the pooler. Only used by the CLI — not the runtime client.
  directUrl = env("DIRECT_URL")
}

model StrategyRun {
  id              String   @id @default(cuid())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  status          String   @default("pending")
  /// step_by_step = pause for human review between major phases; end_to_end = run without those pauses
  runMode         String   @default("step_by_step")
  /// When false, context step skips Memory repository search entirely (set at run creation).
  usePriorRunMemory Boolean @default(true)
  /// When status is awaiting_review: after_discovery | after_structure | after_analysis
  reviewCheckpoint String?
  prompt          String   @db.Text
  companyContext  String   @default("") @db.Text
  discoveryOutput String?  @db.Text
  /// Optional answers to clarifying questions from the context step; merged into discoveryOutput before structure when user continues.
  clarificationAnswers String? @db.Text
  outline         Json?
  /// Manager critique of the hypothesis tree before leaf analysis; structure is then revised
  treeReviewNotes String?  @db.Text
  nodeStates      Json?
  managerNotes    String?  @db.Text
  synthesis       String?  @db.Text
  progressLog     Json     @default("[]")
  /// Client stream session (query `sid`); set when taking the run lock, cleared on stale recovery.
  streamSessionId String?
  error           String?  @db.Text
  /// User interrupt: synthesize_now (consumed by orchestrator when checked)
  controlAction   String?
  controlNote     String?  @db.Text
  /// Legacy steering text; no longer appended (kept for older runs)
  redirectContext String  @default("") @db.Text
  synthesisIsPartial Boolean @default(false)
  /// Aggregated Gemini usage for this run (input/output tokens, by phase); updated when execution finishes or fails.
  tokenUsage      Json?
}

model MemoryArtifact {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  /// When the strategy run began (copied from StrategyRun.createdAt) for display in Memory
  runStartedAt DateTime?
  title     String
  summary   String   @db.Text
  topics    String   @default("") @db.Text
  payload   Json
  runId     String?
}
